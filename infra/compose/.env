# ─────────────────────────────────────────────────────────────────────────────
# BankPortal — .env  v1.9.0  (LOCAL STG)
# Sprint 9 · FEAT-007 · DEBT-011/012
# NUNCA COMMITEAR ESTE ARCHIVO CON VALORES REALES EN REPOSITORIOS PÚBLICOS
# ─────────────────────────────────────────────────────────────────────────────

# Docker
REGISTRY=registry.meridian.internal
IMAGE_TAG=local-dev

# Perfil Spring
SPRING_PROFILE=staging

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
DB_URL=jdbc:postgresql://postgres:5432/bankportal
DB_USER=bankportal
DB_PASSWORD=bankportal_stg_2026
POSTGRES_DB=bankportal

# ── Redis — DEBT-011: SSE Pub/Sub multi-pod ───────────────────────────────────
# IMPORTANTE: REDIS_URL debe tener la password literal (no usa ${VAR} en .env)
REDIS_PASSWORD=redis_stg_2026
REDIS_URL=redis://:redis_stg_2026@redis:6379

# ── JWT — RS256 ────────────────────────────────────────────────────────────────
# Para entorno local STG se puede usar una clave de prueba (NO usar en PROD)
# Generar par real: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Luego base64: base64 -i private.pem | tr -d '\n'
JWT_PRIVATE_
JWT_PUBLIC_

# ── TOTP ──────────────────────────────────────────────────────────────────────
# Generar: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=ORtJcDSlw+vrzjvcGW0scagf6+VtmvdDisz1XWH5v5k=

# ── Notificaciones ────────────────────────────────────────────────────────────
TEAMS_WEBHOOK=
