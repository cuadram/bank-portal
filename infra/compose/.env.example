# ─────────────────────────────────────────────────────────────────────────────
# BankPortal — .env.example  v1.9.0
# Sprint 9 · FEAT-007 · DEBT-011/012
# CLONAR COMO .env Y RELLENAR. NUNCA COMMITEAR .env CON VALORES REALES.
# ─────────────────────────────────────────────────────────────────────────────

# Docker
REGISTRY=registry.meridian.internal
IMAGE_TAG=v1.9.0-rc

# Perfil Spring
SPRING_PROFILE=staging

# Base de datos (PostgreSQL)
DB_URL=jdbc:postgresql://postgres:5432/bankportal
DB_USER=bankportal
DB_PASSWORD=
POSTGRES_DB=bankportal

# Redis — DEBT-011: SSE Pub/Sub multi-pod
# Formato: redis://:password@host:port
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=

# JWT — RS256 — generar keypair: openssl genrsa -out private.pem 2048
# Base64 del contenido PEM sin cabeceras
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# TOTP — generar: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=

# Notificaciones
TEAMS_WEBHOOK=

# OpenPDF / Extractos US-704
# (sin secrets — configuración en application.yml)
