# ─────────────────────────────────────────────────────────────────────────────
# BankPortal — .env.example
# CLONAR ESTE ARCHIVO COMO .env Y RELLENAR LOS VALORES REALES
# NUNCA COMMITEAR .env CON VALORES REALES
# ─────────────────────────────────────────────────────────────────────────────

# Docker
REGISTRY=registry.experis.com/bankportal
IMAGE_TAG=latest-dev

# Base de datos
DB_PASSWORD=

# Cifrado TOTP — generar con: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=

# JWT — generar con: openssl rand -base64 64 | tr -d '\n'
JWT_PARTIAL_SECRET=
JWT_FULL_SECRET=

# Notificaciones
TEAMS_WEBHOOK=
