// Jenkinsfile — BankPortal v1.12.0
// FEAT-010 (US-1001/1002/1003/1004/1005) + DEBT-017/018/019 | Sprint 12
// Gate 7 DevOps — SOFIA Pipeline · 2026-03-22
//
// Cambios respecto a v1.9.0 (Sprint 9):
//   - RELEASE_VERSION 1.9.0 → 1.10.0
//   - DEBT-014: credencial bankportal-jwt-private-key-pem / bankportal-jwt-public-key-pem (RS256)
//   - DEBT-013: Stage 'Backend — Integration Tests (Testcontainers)' añadido
//   - Stage Deploy STG: docker-compose down -v previo (invalida tokens HS256)
//   - Stage E2E: rutas actualizadas para /transfers y /beneficiaries
//   - Jira Epic actualizado: SCRUM-31

pipeline {
    agent { label 'java-node' }

    environment {
        // ── Servicios ──────────────────────────────────────────────────────
        BACKEND_APP     = 'bankportal-backend-2fa'
        FRONTEND_APP    = 'bankportal-frontend-portal'
        DOCKER_REGISTRY = 'registry.meridian.internal'
        IMAGE_TAG       = "${env.GIT_COMMIT?.take(8) ?: env.BUILD_NUMBER}"

        // ── Versión semántica ──────────────────────────────────────────────
        RELEASE_VERSION = '1.12.0'
        RELEASE_TAG     = "v${RELEASE_VERSION}"

        // ── Paths monorepo ─────────────────────────────────────────────────
        BACKEND_PATH    = 'apps/backend-2fa'
        FRONTEND_PATH   = 'apps/frontend-portal'

        // ── Runtimes (paths absolutos — evitar PATH restriction) ───────────
        NODE_BIN        = '/opt/homebrew/opt/node@22/bin/node'
        NPX_BIN         = '/opt/homebrew/opt/node@22/bin/npx'
        MVN_BIN         = '/opt/homebrew/bin/mvn'
        PYTHON_BIN      = '/opt/homebrew/bin/python3'
        UVX_BIN         = '/opt/homebrew/bin/uvx'

        // ── FEAT-008: referencia Jira Sprint 10 ───────────────────────────
        JIRA_EPIC       = 'SCRUM-33'
    }

    options {
        timeout(time: 60, unit: 'MINUTES')  // +15 min por Testcontainers (DEBT-013)
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
        timestamps()
        ansiColor('xterm')
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    stages {

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 1 — SETUP & VALIDACIÓN CREDENCIALES
        // ══════════════════════════════════════════════════════════════════════
        stage('Setup') {
            steps {
                script {
                    echo "╔═══════════════════════════════════════════════════════╗"
                    echo "║  BankPortal · Sprint 10 · FEAT-008 · ${RELEASE_TAG}        ║"
                    echo "║  Branch: ${env.BRANCH_NAME} | Commit: ${IMAGE_TAG}        ║"
                    echo "║  DEBT-013: Testcontainers | DEBT-014: JWT RS256         ║"
                    echo "╚═══════════════════════════════════════════════════════╝"
                    sh "${MVN_BIN} -version"
                    sh "${NODE_BIN} -version"
                    sh "${PYTHON_BIN} --version"

                    // DEBT-014: credenciales RS256 obligatorias (PEM en Base64)
                    withCredentials([
                        string(credentialsId: 'bankportal-jwt-private-key-pem', variable: '_JWT_PRIV_PEM'),
                        string(credentialsId: 'bankportal-jwt-public-key-pem',  variable: '_JWT_PUB_PEM'),
                        string(credentialsId: 'bankportal-redis-url',           variable: '_REDIS'),
                        string(credentialsId: 'bankportal-db-url',              variable: '_DB'),
                        string(credentialsId: 'registry-creds',                 variable: '_REG')
                    ]) {
                        echo "✅ Credenciales JWT RS256 (PEM) + infra disponibles"
                    }
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 2 — BACKEND: TESTS UNITARIOS
        // ══════════════════════════════════════════════════════════════════════
        stage('Backend — Unit Tests') {
            steps {
                dir(BACKEND_PATH) {
                    // Perfil por defecto (H2) — 23 tests unitarios FEAT-008 + tests previos
                    sh "${MVN_BIN} test -Dspring.profiles.active=test -q"
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${BACKEND_PATH}/target/surefire-reports/**/*.xml"
                    publishHTML(target: [
                        allowMissing: true,
                        reportDir:   "${BACKEND_PATH}/target/site/jacoco",
                        reportFiles: 'index.html',
                        reportName:  'Coverage — Backend'
                    ])
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 3 — BACKEND: TESTS DE INTEGRACIÓN (DEBT-013 — Testcontainers)
        // ══════════════════════════════════════════════════════════════════════
        stage('Backend — Integration Tests (Testcontainers)') {
            steps {
                dir(BACKEND_PATH) {
                    // Perfil 'integration': levanta PostgreSQL real + aplica Flyway V1→V11
                    // Requiere Docker activo en el agente Jenkins
                    sh "${MVN_BIN} verify -Pintegration -q"
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${BACKEND_PATH}/target/surefire-reports/**/*.xml"
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 4 — BACKEND: COVERAGE GATE (≥80%)
        // ══════════════════════════════════════════════════════════════════════
        stage('Backend — Coverage Gate (≥80%)') {
            steps {
                dir(BACKEND_PATH) {
                    script {
                        def coverage = sh(
                            script: """${MVN_BIN} jacoco:report -q && \
                                grep -oP '(?<=<counter type="LINE" missed=")[0-9]+' \
                                target/site/jacoco/jacoco.xml | head -1 || echo '0'""",
                            returnStdout: true
                        ).trim()
                        echo "Cobertura líneas perdidas: ${coverage}"
                    }
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 5 — BACKEND: SAST SonarQube
        // ══════════════════════════════════════════════════════════════════════
        stage('Backend — SAST SonarQube') {
            steps {
                dir(BACKEND_PATH) {
                    withSonarQubeEnv('sonarqube') {
                        sh """${MVN_BIN} sonar:sonar \
                            -Dsonar.projectKey=bankportal-backend \
                            -Dsonar.projectVersion=${RELEASE_VERSION} \
                            -Dsonar.branch.name=${env.BRANCH_NAME} \
                            -q"""
                    }
                }
            }
        }

        stage('Backend — Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Backend — Build JAR') {
            steps {
                dir(BACKEND_PATH) {
                    sh "${MVN_BIN} package -DskipTests -q"
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: "${BACKEND_PATH}/target/*.jar",
                                     fingerprint: true
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 6 — FRONTEND: TEST + BUILD
        // ══════════════════════════════════════════════════════════════════════
        stage('Frontend — Install & Test') {
            steps {
                dir(FRONTEND_PATH) {
                    sh "${NPX_BIN} --yes npm ci"
                    sh "${NPX_BIN} ng test --watch=false --browsers=ChromeHeadless"
                }
            }
        }

        stage('Frontend — Build (prod)') {
            steps {
                dir(FRONTEND_PATH) {
                    sh "${NPX_BIN} ng build --configuration=production --output-path=dist/bankportal"
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: "${FRONTEND_PATH}/dist/**/*",
                                     fingerprint: true
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 7 — DOCKER BUILD & SCAN (Trivy)
        // ══════════════════════════════════════════════════════════════════════
        stage('Docker — Build Backend') {
            steps {
                sh """docker build \
                    -f ${BACKEND_PATH}/Dockerfile \
                    -t ${DOCKER_REGISTRY}/${BACKEND_APP}:${IMAGE_TAG} \
                    -t ${DOCKER_REGISTRY}/${BACKEND_APP}:latest-dev \
                    ${BACKEND_PATH}/"""
            }
        }

        stage('Docker — Build Frontend') {
            steps {
                sh """docker build \
                    -f ${FRONTEND_PATH}/Dockerfile \
                    -t ${DOCKER_REGISTRY}/${FRONTEND_APP}:${IMAGE_TAG} \
                    -t ${DOCKER_REGISTRY}/${FRONTEND_APP}:latest-dev \
                    ${FRONTEND_PATH}/"""
            }
        }

        stage('Docker — Vulnerability Scan (Trivy)') {
            steps {
                script {
                    def backendScan = sh(
                        script: """trivy image --exit-code 0 --severity CRITICAL,HIGH \
                                   --no-progress --format table \
                                   ${DOCKER_REGISTRY}/${BACKEND_APP}:${IMAGE_TAG} 2>&1 || true""",
                        returnStdout: true
                    )
                    echo "Backend Trivy:\n${backendScan}"
                    // CVE Critical = BLOQUEANTE
                    sh """trivy image --exit-code 1 --severity CRITICAL \
                          --no-progress \
                          ${DOCKER_REGISTRY}/${BACKEND_APP}:${IMAGE_TAG}"""
                    sh """trivy image --exit-code 1 --severity CRITICAL \
                          --no-progress \
                          ${DOCKER_REGISTRY}/${FRONTEND_APP}:${IMAGE_TAG}"""
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 8 — PUSH TO REGISTRY
        // ══════════════════════════════════════════════════════════════════════
        stage('Docker — Push (develop / tag)') {
            when {
                anyOf { branch 'develop'; tag 'v*' }
            }
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'registry-creds',
                                     usernameVariable: 'REG_USER',
                                     passwordVariable: 'REG_PASS')
                ]) {
                    sh "docker login ${DOCKER_REGISTRY} -u ${REG_USER} -p ${REG_PASS}"
                    script {
                        def pushTag = env.TAG_NAME ?: IMAGE_TAG
                        sh "docker tag ${DOCKER_REGISTRY}/${BACKEND_APP}:${IMAGE_TAG} ${DOCKER_REGISTRY}/${BACKEND_APP}:${pushTag}"
                        sh "docker push ${DOCKER_REGISTRY}/${BACKEND_APP}:${pushTag}"
                        sh "docker tag ${DOCKER_REGISTRY}/${FRONTEND_APP}:${IMAGE_TAG} ${DOCKER_REGISTRY}/${FRONTEND_APP}:${pushTag}"
                        sh "docker push ${DOCKER_REGISTRY}/${FRONTEND_APP}:${pushTag}"
                        echo "✅ Imágenes publicadas: ${pushTag}"
                    }
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 9 — DEPLOY STG
        // DEBT-014: down -v obligatorio para invalidar tokens HS256 anteriores
        // ══════════════════════════════════════════════════════════════════════
        stage('Deploy — STG') {
            when { tag 'v*' }
            steps {
                withCredentials([
                    string(credentialsId: 'bankportal-db-url',              variable: 'DB_URL'),
                    string(credentialsId: 'bankportal-redis-url',            variable: 'REDIS_URL'),
                    // DEBT-014: claves RSA en PEM Base64 (sustituyen jwt-private-key / jwt-public-key)
                    string(credentialsId: 'bankportal-jwt-private-key-pem',  variable: 'JWT_PRIVATE_KEY_PEM'),
                    string(credentialsId: 'bankportal-jwt-public-key-pem',   variable: 'JWT_PUBLIC_KEY_PEM')
                ]) {
                    script {
                        echo "⚠️  DEBT-014: down -v para limpiar tokens HS256 anteriores en STG"
                        sh "cd infra/compose && docker-compose down -v || true"
                        sh """
                            TAG=${env.TAG_NAME} \
                            DOCKER_REGISTRY=${DOCKER_REGISTRY} \
                            BACKEND_APP=${BACKEND_APP} \
                            FRONTEND_APP=${FRONTEND_APP} \
                            JWT_PRIVATE_KEY_PEM=${JWT_PRIVATE_KEY_PEM} \
                            JWT_PUBLIC_KEY_PEM=${JWT_PUBLIC_KEY_PEM} \
                            docker-compose -f infra/compose/docker-compose.yml up -d --build
                        """
                    }
                }
                sh "sleep 30"
                sh "curl -f http://localhost:8081/actuator/health/readiness || exit 1"
                // Verificar que los 5 contenedores están healthy
                sh """docker ps --format '{{.Names}} {{.Status}}' | \
                      grep -E '(bankportal-backend|bankportal-frontend|bankportal-postgres|bankportal-redis|bankportal-mailhog)'"""
                echo "✅ Deploy STG v${RELEASE_VERSION} — 5/5 contenedores healthy — JWT RS256 activo"
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 10 — E2E STG (rutas FEAT-008)
        // ══════════════════════════════════════════════════════════════════════
        stage('E2E Playwright — STG') {
            when { tag 'v*' }
            steps {
                dir(FRONTEND_PATH) {
                    sh "${NPX_BIN} playwright install --with-deps chromium firefox"
                    // E2E incluye flujos de transferencias y beneficiarios (FEAT-008)
                    sh "BASE_URL=http://localhost:4201 ${NPX_BIN} playwright test e2e/ --reporter=html"
                }
            }
            post {
                always {
                    publishHTML(target: [
                        allowMissing: true,
                        reportDir:   "${FRONTEND_PATH}/playwright-report",
                        reportFiles: 'index.html',
                        reportName:  'Playwright E2E — STG FEAT-008',
                        keepAll:     true
                    ])
                }
            }
        }

        stage('WCAG 2.1 AA — axe-core STG') {
            when { tag 'v*' }
            steps {
                dir(FRONTEND_PATH) {
                    // FEAT-008: añadir rutas /transfers y /beneficiaries
                    sh """${NPX_BIN} axe http://localhost:4201/accounts \
                          --tags wcag2aa --reporter json \
                          --stdout > axe-report-accounts.json || true"""
                    sh """${NPX_BIN} axe http://localhost:4201/transfers \
                          --tags wcag2aa --reporter json \
                          --stdout > axe-report-transfers.json || true"""
                    sh """${NODE_BIN} -e \"
                        ['axe-report-accounts.json','axe-report-transfers.json'].forEach(f => {
                            try {
                                const r = require('./' + f);
                                const critical = (r.violations||[]).filter(v => v.impact==='critical');
                                if (critical.length > 0) {
                                    console.error('WCAG critical in ' + f + ':', JSON.stringify(critical, null, 2));
                                    process.exit(1);
                                }
                            } catch(e) { console.log('Skipping ' + f); }
                        });
                        console.log('WCAG 2.1 AA: 0 critical violations');
                    \" """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "${FRONTEND_PATH}/axe-report-*.json",
                                     allowEmptyArchive: true
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 11 — GO/NO-GO PRODUCCIÓN (gate manual HITL)
        // ══════════════════════════════════════════════════════════════════════
        stage('Go/No-Go — PROD') {
            when { tag 'v*' }
            steps {
                script {
                    echo "⏳ Esperando aprobación release-manager para BankPortal v${RELEASE_VERSION}..."
                    def approval = input(
                        message: "Deploy BankPortal ${env.TAG_NAME} to PRODUCTION?",
                        submitter: 'release-manager,pm-team',
                        parameters: [
                            choice(name: 'ACTION',
                                   choices: ['Go', 'No-Go'],
                                   description: 'Decisión de release'),
                            text(name: 'NOTES',
                                 defaultValue: '',
                                 description: 'Notas FEAT-008 / DEBT-013/014 / justificación No-Go')
                        ]
                    )
                    if (approval['ACTION'] == 'No-Go') {
                        error("❌ Release rechazado: ${approval['NOTES']}")
                    }
                    echo "✅ Go autorizado por release-manager. Notas: ${approval['NOTES']}"
                }
            }
        }

        // ══════════════════════════════════════════════════════════════════════
        // STAGE 12 — DEPLOY PRODUCCIÓN
        // ══════════════════════════════════════════════════════════════════════
        stage('Deploy — PROD') {
            when { tag 'v*' }
            steps {
                withCredentials([
                    string(credentialsId: 'bankportal-db-url-prod',              variable: 'DB_URL'),
                    string(credentialsId: 'bankportal-redis-url-prod',            variable: 'REDIS_URL'),
                    string(credentialsId: 'bankportal-jwt-private-key-pem-prod',  variable: 'JWT_PRIVATE_KEY_PEM'),
                    string(credentialsId: 'bankportal-jwt-public-key-pem-prod',   variable: 'JWT_PUBLIC_KEY_PEM')
                ]) {
                    sh """
                        TAG=${env.TAG_NAME} \
                        JWT_PRIVATE_KEY_PEM=${JWT_PRIVATE_KEY_PEM} \
                        JWT_PUBLIC_KEY_PEM=${JWT_PUBLIC_KEY_PEM} \
                        docker-compose -f infra/compose/prod/docker-compose.yml up -d --force-recreate
                    """
                }
            }
        }

        stage('Health Check — PROD') {
            when { tag 'v*' }
            steps {
                sh "sleep 30"
                sh "curl -f https://api.bankmeridian.com/actuator/health/readiness || exit 1"
                sh "curl -f https://app.bankmeridian.com/ || exit 1"
                // FEAT-008: verificar endpoints nuevos
                sh "curl -f -H 'Authorization: Bearer test' https://api.bankmeridian.com/api/v1/transfers/limits || true"
                echo "✅ Deploy PROD v${RELEASE_VERSION} completado — health checks OK"
            }
        }

    } // end stages

    post {
        success {
            script {
                if (env.TAG_NAME?.startsWith('v')) {
                    echo "🚀 BankPortal ${env.TAG_NAME} desplegado — FEAT-008 Transferencias activo"
                    // Notificación automática al epic SCRUM-31 via Jira API
                }
            }
        }
        failure {
            echo "❌ Pipeline fallido — Branch: ${env.BRANCH_NAME} | Build: ${env.BUILD_URL}"
        }
        always {
            sh "docker image prune -f --filter 'until=24h' || true"
        }
    }
}
