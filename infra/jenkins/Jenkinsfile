// Jenkinsfile — BankPortal v1.15.0
// FEAT-013 KYC Onboarding (US-1301..1307) + RV-020/SAST-001/SAST-002 + RV-021..024 | Sprint 15
// Gate 7 DevOps — SOFIA Pipeline · 2026-03-24
//
// Historial:
//   v1.10.0 (Sprint 10): FEAT-008 Transferencias + DEBT-013/014
//   v1.11.0 (Sprint 11): FEAT-009 Pagos de servicios + core bancario real
//   v1.12.0 (Sprint 12): FEAT-010 Dashboard backend
//   v1.13.0 (Sprint 13): FEAT-011 Frontend Angular Dashboard + exportación PDF/Excel
//   v1.14.0 (Sprint 14): FEAT-012-A Gestión de Perfil + DEBT-022/023 + RV-013..023
//   v1.15.0 (Sprint 15): FEAT-013 KYC Onboarding + RV-020/SAST-001/002 + RV-021..024

pipeline {
    agent { label 'java-node' }

    environment {
        BACKEND_APP     = 'bankportal-backend-2fa'
        FRONTEND_APP    = 'bankportal-frontend-portal'
        DOCKER_REGISTRY = 'registry.meridian.internal'
        IMAGE_TAG       = "${env.GIT_COMMIT?.take(8) ?: env.BUILD_NUMBER}"

        RELEASE_VERSION = '1.15.0'
        RELEASE_TAG     = "v${RELEASE_VERSION}"

        BACKEND_PATH    = 'apps/backend-2fa'
        FRONTEND_PATH   = 'apps/frontend-portal'
        INFRA_PATH      = 'infra'

        JIRA_PROJECT    = 'SCRUM'
        JIRA_EPIC       = 'SCRUM-36'
        FEATURE_BRANCH  = 'feature/FEAT-013-sprint15'

        JAVA_VERSION    = '21'
        NODE_VERSION    = '22'
        MAVEN_OPTS      = '-Xmx1g'
    }

    options {
        timeout(time: 45, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {

        // ── Stage 0: Checkout + validation ──────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                sh 'java -version && mvn -version && node -v && npm -v'
                echo "Build ${env.BUILD_NUMBER} — ${env.RELEASE_TAG} — commit ${env.IMAGE_TAG}"
            }
        }

        // ── Stage 1: Backend — Build + Tests ────────────────────────────────
        stage('Backend: Build & Test') {
            steps {
                dir(env.BACKEND_PATH) {
                    sh '''
                        mvn clean verify \
                          -Dspring.profiles.active=test \
                          -Djacoco.minimum.coverage=0.80 \
                          -B -q
                    '''
                }
            }
            post {
                always {
                    junit "${env.BACKEND_PATH}/target/surefire-reports/*.xml"
                    jacoco(
                        execPattern: "${env.BACKEND_PATH}/target/jacoco.exec",
                        classPattern: "${env.BACKEND_PATH}/target/classes",
                        sourcePattern: "${env.BACKEND_PATH}/src/main/java",
                        minimumLineCoverage: '80',
                        minimumBranchCoverage: '80'
                    )
                }
            }
        }

        // ── Stage 2: Flyway migration validation ────────────────────────────
        stage('Flyway: Validate V15 migration') {
            steps {
                dir(env.BACKEND_PATH) {
                    sh '''
                        mvn flyway:validate \
                          -Dflyway.url=${DB_URL_CI} \
                          -Dflyway.user=${DB_USER_CI} \
                          -Dflyway.password=${DB_PASS_CI} \
                          -B -q
                    '''
                }
            }
        }

        // ── Stage 3: Frontend — Build + Tests ───────────────────────────────
        stage('Frontend: Build & Test') {
            steps {
                dir(env.FRONTEND_PATH) {
                    sh '''
                        npm ci --silent
                        npx ng test --watch=false --browsers=ChromeHeadless \
                          --code-coverage --progress=false
                        npx ng build --configuration=production \
                          --output-hashing=all
                    '''
                }
            }
            post {
                always {
                    junit "${env.FRONTEND_PATH}/test-results/*.xml"
                }
            }
        }

        // ── Stage 4: Docker build — Backend ─────────────────────────────────
        stage('Docker: Build Backend') {
            steps {
                dir(env.BACKEND_PATH) {
                    sh """
                        docker build \
                          --build-arg RELEASE_VERSION=${env.RELEASE_VERSION} \
                          --build-arg GIT_COMMIT=${env.IMAGE_TAG} \
                          -t ${env.DOCKER_REGISTRY}/${env.BACKEND_APP}:${env.IMAGE_TAG} \
                          -t ${env.DOCKER_REGISTRY}/${env.BACKEND_APP}:${env.RELEASE_TAG} \
                          .
                    """
                }
            }
        }

        // ── Stage 5: Docker build — Frontend ────────────────────────────────
        stage('Docker: Build Frontend') {
            steps {
                dir(env.FRONTEND_PATH) {
                    sh """
                        docker build \
                          --build-arg RELEASE_VERSION=${env.RELEASE_VERSION} \
                          -t ${env.DOCKER_REGISTRY}/${env.FRONTEND_APP}:${env.IMAGE_TAG} \
                          -t ${env.DOCKER_REGISTRY}/${env.FRONTEND_APP}:${env.RELEASE_TAG} \
                          .
                    """
                }
            }
        }

        // ── Stage 6: Push to registry ────────────────────────────────────────
        stage('Docker: Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-registry-credentials',
                    usernameVariable: 'REGISTRY_USER',
                    passwordVariable: 'REGISTRY_PASS'
                )]) {
                    sh """
                        echo ${env.REGISTRY_PASS} | docker login ${env.DOCKER_REGISTRY} \
                          -u ${env.REGISTRY_USER} --password-stdin
                        docker push ${env.DOCKER_REGISTRY}/${env.BACKEND_APP}:${env.IMAGE_TAG}
                        docker push ${env.DOCKER_REGISTRY}/${env.BACKEND_APP}:${env.RELEASE_TAG}
                        docker push ${env.DOCKER_REGISTRY}/${env.FRONTEND_APP}:${env.IMAGE_TAG}
                        docker push ${env.DOCKER_REGISTRY}/${env.FRONTEND_APP}:${env.RELEASE_TAG}
                    """
                }
            }
        }

        // ── Stage 7: Deploy STG ──────────────────────────────────────────────
        stage('Deploy: STG') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-stg']) {
                    sh """
                        kubectl set image deployment/bankportal-2fa \
                          bankportal-2fa=${env.DOCKER_REGISTRY}/${env.BACKEND_APP}:${env.IMAGE_TAG} \
                          -n bankportal-stg
                        kubectl set image deployment/bankportal-frontend \
                          bankportal-frontend=${env.DOCKER_REGISTRY}/${env.FRONTEND_APP}:${env.IMAGE_TAG} \
                          -n bankportal-stg
                        kubectl rollout status deployment/bankportal-2fa -n bankportal-stg --timeout=3m
                        kubectl rollout status deployment/bankportal-frontend -n bankportal-stg --timeout=2m
                    """
                }
            }
        }

        // ── Stage 8: Smoke tests STG ─────────────────────────────────────────
        stage('Smoke: STG') {
            steps {
                sh '''
                    # KYC endpoints health check
                    curl -sf https://api-stg.bankportal.meridian.com/actuator/health | grep -q "UP"

                    # Verify KYC_REQUIRED guard is active
                    STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
                      -X POST https://api-stg.bankportal.meridian.com/api/v1/transfers \
                      -H "Authorization: Bearer ${SMOKE_TEST_TOKEN_NO_KYC}")
                    [ "$STATUS" = "403" ] || (echo "KYC guard smoke test FAILED: expected 403, got $STATUS" && exit 1)

                    echo "Smoke tests STG: PASS"
                '''
            }
        }

        // ── Stage 9: Deploy PROD (manual gate) ───────────────────────────────
        stage('Deploy: PROD') {
            when { branch 'develop' }
            input {
                message "¿Desplegar v${env.RELEASE_VERSION} en PROD?"
                ok 'Confirmar deploy'
                submitter 'release-manager'
            }
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-prod']) {
                    sh """
                        kubectl set image deployment/bankportal-2fa \
                          bankportal-2fa=${env.DOCKER_REGISTRY}/${env.BACKEND_APP}:${env.RELEASE_TAG} \
                          -n bankportal-prod
                        kubectl set image deployment/bankportal-frontend \
                          bankportal-frontend=${env.DOCKER_REGISTRY}/${env.FRONTEND_APP}:${env.RELEASE_TAG} \
                          -n bankportal-prod
                        kubectl rollout status deployment/bankportal-2fa -n bankportal-prod --timeout=5m
                        kubectl rollout status deployment/bankportal-frontend -n bankportal-prod --timeout=3m
                    """
                }
            }
        }

        // ── Stage 10: Git tag ─────────────────────────────────────────────────
        stage('Git: Tag release') {
            when { branch 'develop' }
            steps {
                sh """
                    git tag -a ${env.RELEASE_TAG} -m "Release ${env.RELEASE_TAG} — Sprint 15 FEAT-013 KYC"
                    git push origin ${env.RELEASE_TAG}
                """
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline v${env.RELEASE_VERSION} completado — ${env.RELEASE_TAG}"
        }
        failure {
            echo "❌ Pipeline fallido en stage: ${env.STAGE_NAME}"
        }
        always {
            cleanWs()
        }
    }
}
