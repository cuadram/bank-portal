// Jenkinsfile — BankPortal v1.14.0
// FEAT-012-A (US-1201/1202/1203/1204/1205) + DEBT-022/023 + RV-013..023 | Sprint 14
// Gate 7 DevOps — SOFIA Pipeline · 2026-03-23
//
// Cambios respecto a v1.13.0 (Sprint 13):
//   - RELEASE_VERSION 1.13.0 → 1.14.0
//   - DEBT-022: OAuth2ResourceServerAutoConfiguration excluida — fix 403 STG
//   - DEBT-023: JWT incluye jti UUID v4 — revocación de sesiones habilitada
//   - Módulo profile: ProfileController, ChangePasswordUseCase, ManageSessionsUseCase
//   - Módulo dashboard: portado desde FEAT-011 + RV-013/014/015 aplicados
//   - Flyway V14: user_profiles, user_notification_preferences, password_history, revoked_tokens
//   - Stage 'Backend — Integration Tests': incluye tests de módulo profile
//   - Stage Deploy STG: sin docker-compose down -v (tokens no requieren rotación)
//   - Jira Epic: SCRUM-35

pipeline {
    agent { label 'java-node' }

    environment {
        BACKEND_APP     = 'bankportal-backend-2fa'
        FRONTEND_APP    = 'bankportal-frontend-portal'
        DOCKER_REGISTRY = 'registry.meridian.internal'
        IMAGE_TAG       = "${env.GIT_COMMIT?.take(8) ?: env.BUILD_NUMBER}"

        RELEASE_VERSION = '1.14.0'
        RELEASE_TAG     = "v${RELEASE_VERSION}"

        BACKEND_PATH    = 'apps/backend-2fa'
        FRONTEND_PATH   = 'apps/frontend-portal'
        INFRA_PATH      = 'infra'

        JIRA_PROJECT    = 'SCRUM'
        JIRA_EPIC       = 'SCRUM-35'
        FEATURE_BRANCH  = 'feature/FEAT-012-sprint14'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
    }

    stages {

        // ── Stage 1: Checkout & Validación rama ──────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                sh '''
                    echo "Branch: ${GIT_BRANCH}"
                    echo "Commit: ${GIT_COMMIT}"
                    echo "Release: v${RELEASE_VERSION}"
                    git log --oneline -5
                '''
            }
        }

        // ── Stage 2: Backend — Build & Unit Tests ────────────────────────────
        stage('Backend — Build & Unit Tests') {
            steps {
                dir("${BACKEND_PATH}") {
                    sh '''
                        ./mvnw clean verify \
                          -Djacoco.minimum.coverage=0.80 \
                          -Dsurefire.excludes="**/*E2ETest.java,**/*IntegrationTest.java" \
                          -B -q
                    '''
                }
            }
            post {
                always {
                    junit "${BACKEND_PATH}/target/surefire-reports/*.xml"
                    jacoco(
                        execPattern: "${BACKEND_PATH}/target/jacoco.exec",
                        classPattern: "${BACKEND_PATH}/target/classes",
                        sourcePattern: "${BACKEND_PATH}/src/main/java",
                        minimumInstructionCoverage: '80'
                    )
                }
            }
        }

        // ── Stage 3: Frontend — Build & Lint ─────────────────────────────────
        stage('Frontend — Build & Lint') {
            steps {
                dir("${FRONTEND_PATH}") {
                    sh '''
                        npm ci --prefer-offline
                        npm run lint -- --max-warnings=0
                        npm run build -- --configuration production
                    '''
                }
            }
        }

        // ── Stage 4: Backend — Integration Tests (Testcontainers) ────────────
        stage('Backend — Integration Tests') {
            when { branch "${FEATURE_BRANCH}" }
            steps {
                dir("${BACKEND_PATH}") {
                    sh '''
                        ./mvnw verify -Pintegration \
                          -Dsurefire.excludes=NINGUNO \
                          -B -q
                    '''
                }
            }
            post {
                always {
                    junit "${BACKEND_PATH}/target/surefire-reports/*.xml"
                }
            }
        }

        // ── Stage 5: Docker Build ─────────────────────────────────────────────
        stage('Docker Build') {
            steps {
                sh '''
                    docker build \
                      -t ${DOCKER_REGISTRY}/${BACKEND_APP}:${IMAGE_TAG} \
                      -t ${DOCKER_REGISTRY}/${BACKEND_APP}:latest \
                      -f ${BACKEND_PATH}/Dockerfile \
                      ${BACKEND_PATH}

                    docker build \
                      -t ${DOCKER_REGISTRY}/${FRONTEND_APP}:${IMAGE_TAG} \
                      -t ${DOCKER_REGISTRY}/${FRONTEND_APP}:latest \
                      -f ${FRONTEND_PATH}/Dockerfile \
                      ${FRONTEND_PATH}
                '''
            }
        }

        // ── Stage 6: Docker Push ──────────────────────────────────────────────
        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-registry-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "${DOCKER_PASS}" | docker login ${DOCKER_REGISTRY} \
                          -u "${DOCKER_USER}" --password-stdin
                        docker push ${DOCKER_REGISTRY}/${BACKEND_APP}:${IMAGE_TAG}
                        docker push ${DOCKER_REGISTRY}/${BACKEND_APP}:latest
                        docker push ${DOCKER_REGISTRY}/${FRONTEND_APP}:${IMAGE_TAG}
                        docker push ${DOCKER_REGISTRY}/${FRONTEND_APP}:latest
                    '''
                }
            }
        }

        // ── Stage 7: Deploy STG ───────────────────────────────────────────────
        stage('Deploy STG') {
            steps {
                withCredentials([
                    string(credentialsId: 'bankportal-jwt-secret',     secretVariable: 'JWT_SECRET'),
                    string(credentialsId: 'bankportal-db-password',    secretVariable: 'DB_PASSWORD'),
                    string(credentialsId: 'bankportal-redis-url',      secretVariable: 'REDIS_URL'),
                    string(credentialsId: 'bankportal-totp-aes-key',   secretVariable: 'TOTP_AES_KEY')
                ]) {
                    sh '''
                        cd ${INFRA_PATH}/compose

                        # FEAT-012-A: Sin rotación de JWT necesaria (DEBT-022 fix no requiere
                        # invalidar tokens existentes — solo evita doble filtro OAuth2)
                        # Flyway V14 se ejecuta automáticamente al arrancar el backend

                        JWT_SECRET="${JWT_SECRET}" \
                        DB_PASSWORD="${DB_PASSWORD}" \
                        REDIS_URL="${REDIS_URL}" \
                        TOTP_AES_KEY="${TOTP_AES_KEY}" \
                        BACKEND_TAG="${IMAGE_TAG}" \
                        FRONTEND_TAG="${IMAGE_TAG}" \
                        docker-compose up -d --no-recreate

                        # Esperar healthcheck
                        sleep 20
                        curl -f http://localhost:8080/actuator/health || exit 1
                        echo "STG health check: OK"
                    '''
                }
            }
        }

        // ── Stage 8: Smoke Tests STG ──────────────────────────────────────────
        stage('Smoke Tests STG') {
            steps {
                sh '''
                    # DEBT-022 verification: endpoint debe responder 401 (sin token)
                    # en lugar de 403 (OAuth2 filter conflict)
                    STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
                      http://localhost:8080/api/v1/profile)
                    if [ "$STATUS" = "401" ]; then
                      echo "DEBT-022 VERIFIED: /api/v1/profile devuelve 401 sin token (no 403)"
                    else
                      echo "DEBT-022 FAILED: esperado 401, obtenido $STATUS"
                      exit 1
                    fi

                    # Healthcheck general
                    curl -f http://localhost:8080/actuator/health
                    echo "Smoke tests: PASS"
                '''
            }
        }

        // ── Stage 9: Git Tag & Release ────────────────────────────────────────
        stage('Git Tag & Release') {
            when { branch "${FEATURE_BRANCH}" }
            steps {
                withCredentials([gitUsernamePassword(credentialsId: 'github-credentials')]) {
                    sh '''
                        git config user.email "sofia@experis.com"
                        git config user.name "SOFIA Pipeline"
                        git tag -a ${RELEASE_TAG} \
                          -m "Release ${RELEASE_VERSION} — FEAT-012-A Sprint 14
DEBT-022/023 + RV-013..023 + Gestión de Perfil de Usuario
42 TCs PASS | 0 defectos | Security: VERDE"
                        git push origin ${RELEASE_TAG}
                    '''
                }
            }
        }

    } // end stages

    post {
        success {
            echo "✅ Pipeline v${RELEASE_VERSION} completado — BankPortal FEAT-012-A Sprint 14"
        }
        failure {
            echo "❌ Pipeline fallido — revisar logs"
        }
    }
}
