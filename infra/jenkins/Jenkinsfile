// Jenkinsfile — BankPortal v1.14.0
// FEAT-012-A (US-1201/1202/1203/1204/1205) + DEBT-022/023 + RV-013..023 | Sprint 14
// Gate 7 DevOps — SOFIA Pipeline · 2026-03-23
//
// Historial:
//   v1.10.0 (Sprint 10): FEAT-008 Transferencias + DEBT-013/014
//   v1.11.0 (Sprint 11): FEAT-009 Pagos de servicios + core bancario real
//   v1.12.0 (Sprint 12): FEAT-010 Dashboard backend
//   v1.13.0 (Sprint 13): FEAT-011 Frontend Angular Dashboard + exportación PDF/Excel
//   v1.14.0 (Sprint 14): FEAT-012-A Gestión de Perfil + DEBT-022/023 + RV-013..023

pipeline {
    agent { label 'java-node' }

    environment {
        BACKEND_APP     = 'bankportal-backend-2fa'
        FRONTEND_APP    = 'bankportal-frontend-portal'
        DOCKER_REGISTRY = 'registry.meridian.internal'
        IMAGE_TAG       = "${env.GIT_COMMIT?.take(8) ?: env.BUILD_NUMBER}"

        RELEASE_VERSION = '1.14.0'
        RELEASE_TAG     = "v${RELEASE_VERSION}"

        BACKEND_PATH    = 'apps/backend-2fa'
        FRONTEND_PATH   = 'apps/frontend-portal'
        INFRA_PATH      = 'infra'

        JIRA_PROJECT    = 'SCRUM'
        JIRA_EPIC       = 'SCRUM-35'
        FEATURE_BRANCH  = 'feature/FEAT-012-sprint14'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                sh 'git log --oneline -5'
            }
        }

        stage('Backend — Build & Unit Tests') {
            steps {
                dir("${BACKEND_PATH}") {
                    sh './mvnw clean verify -Djacoco.minimum.coverage=0.80 -B -q'
                }
            }
            post {
                always {
                    junit "${BACKEND_PATH}/target/surefire-reports/*.xml"
                }
            }
        }

        stage('Frontend — Build & Lint') {
            steps {
                dir("${FRONTEND_PATH}") {
                    sh 'npm ci --prefer-offline'
                    sh 'npm run lint -- --max-warnings=0'
                    sh 'npm run build -- --configuration production'
                }
            }
        }

        stage('Backend — Integration Tests') {
            steps {
                dir("${BACKEND_PATH}") {
                    sh './mvnw verify -Pintegration -B -q'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    docker build -t ${DOCKER_REGISTRY}/${BACKEND_APP}:${IMAGE_TAG} \
                      -f ${BACKEND_PATH}/Dockerfile ${BACKEND_PATH}
                    docker build -t ${DOCKER_REGISTRY}/${FRONTEND_APP}:${IMAGE_TAG} \
                      -f ${FRONTEND_PATH}/Dockerfile ${FRONTEND_PATH}
                '''
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-registry-credentials',
                        usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh '''
                        echo "${DOCKER_PASS}" | docker login ${DOCKER_REGISTRY} -u "${DOCKER_USER}" --password-stdin
                        docker push ${DOCKER_REGISTRY}/${BACKEND_APP}:${IMAGE_TAG}
                        docker push ${DOCKER_REGISTRY}/${FRONTEND_APP}:${IMAGE_TAG}
                    '''
                }
            }
        }

        stage('Deploy STG') {
            steps {
                withCredentials([
                    string(credentialsId: 'bankportal-jwt-secret',   secretVariable: 'JWT_SECRET'),
                    string(credentialsId: 'bankportal-db-password',  secretVariable: 'DB_PASSWORD'),
                    string(credentialsId: 'bankportal-redis-url',    secretVariable: 'REDIS_URL'),
                    string(credentialsId: 'bankportal-totp-aes-key', secretVariable: 'TOTP_AES_KEY')
                ]) {
                    sh '''
                        cd ${INFRA_PATH}/compose
                        JWT_SECRET="${JWT_SECRET}" DB_PASSWORD="${DB_PASSWORD}" \
                        REDIS_URL="${REDIS_URL}" TOTP_AES_KEY="${TOTP_AES_KEY}" \
                        BACKEND_TAG="${IMAGE_TAG}" FRONTEND_TAG="${IMAGE_TAG}" \
                        docker-compose up -d --no-recreate
                        sleep 20
                        curl -f http://localhost:8080/actuator/health || exit 1
                    '''
                }
            }
        }

        stage('Smoke Tests STG') {
            steps {
                sh '''
                    STATUS=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:8080/api/v1/profile)
                    [ "$STATUS" = "401" ] && echo "DEBT-022 VERIFIED: 401 OK" || (echo "DEBT-022 FAILED: got $STATUS"; exit 1)
                    curl -f http://localhost:8080/actuator/health
                '''
            }
        }

        stage('Git Tag & Release') {
            steps {
                withCredentials([gitUsernamePassword(credentialsId: 'github-credentials')]) {
                    sh '''
                        git config user.email "sofia@experis.com"
                        git config user.name "SOFIA Pipeline"
                        git tag -a ${RELEASE_TAG} -m "Release ${RELEASE_VERSION} — FEAT-012-A Sprint 14"
                        git push origin ${RELEASE_TAG}
                    '''
                }
            }
        }

    }

    post {
        success { echo "✅ BankPortal v${RELEASE_VERSION} — FEAT-012-A Sprint 14 COMPLETADO" }
        failure { echo "❌ Pipeline fallido — revisar logs" }
    }
}
